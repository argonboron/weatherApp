{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@shared/*": ["../../packages/shared/dist/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
